# ORC Project File
# Version: 2.0

project:
  name: videosynth_ntsc_biphase_cav
  version: 2.0
  video_format: NTSC
  source_format: Composite
  amplitude_unit: IRE
dag:
  nodes:
    - id: 1
      stage: NTSC_CVBS_Source
      node_type: SOURCE
      display_name: NTSC CVBS Source
      user_label: NTSC CVBS Source
      x: 50
      y: 50
      parameters:
        input_path:
          type: string
          value: /home/sdi/Coding/videosynth/tests/projects/output-general/videosynth_ntsc_biphase_cav.composite
    - id: 2
      stage: ffmpeg_video_sink
      node_type: SINK
      display_name: FFmpeg Video Sink
      user_label: FFmpeg Video Sink
      x: 500
      y: 50
    - id: 3
      stage: frame_map
      node_type: TRANSFORM
      display_name: Frame Map
      user_label: Frame Map
      x: 275
      y: 50
      parameters:
        ranges:
          type: string
          value: 17-22
  edges:
    - from: 1
      to: 3
    - from: 3
      to: 2