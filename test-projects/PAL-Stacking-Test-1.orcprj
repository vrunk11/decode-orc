          type: string
          value: ../../videosynth/tests/projects/output-stacking/composite/videosynth_pal_stacking_1001.composite
        y_path:
          type: string
          value: ""
    - id: 2
      stage: PAL_CVBS_Source
      node_type: SOURCE
      display_name: PAL CVBS Source
      user_label: PAL CVBS Source
      x: 50
      y: 175
      parameters:
        c_path:
          type: string
          value: ""
        input_path:
          type: string
          value: ../../videosynth/tests/projects/output-stacking/composite/videosynth_pal_stacking_2002.composite
        y_path:
          type: string
          value: ""
    - id: 3
      stage: PAL_CVBS_Source
      node_type: SOURCE
      display_name: PAL CVBS Source
      user_label: PAL CVBS Source
      x: 50
      y: 300
      parameters:
        c_path:
          type: string
          value: ""
        input_path:
          type: string
          value: ../../videosynth/tests/projects/output-stacking/composite/videosynth_pal_stacking_3003.composite
        y_path:
          type: string
          value: ""
    - id: 4
      stage: PAL_CVBS_Source
      node_type: SOURCE
