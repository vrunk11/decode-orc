      y: 425
      parameters:
        c_path:
          type: string
          value: ""
        input_path:
          type: string
          value: ../../videosynth/tests/projects/output-stacking/composite/videosynth_pal_stacking_4004.composite
        y_path:
          type: string
          value: ""
    - id: 5
      stage: stacker
      node_type: MERGER
      display_name: Stacker
      user_label: Stacker
      x: 275
      y: 50
      parameters:
        audio_stacking:
          type: string
