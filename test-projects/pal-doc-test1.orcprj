# ORC Project File
# Version: 2.0

project:
  name: set1_side1
  version: 2.0
  video_format: PAL
  source_format: Composite
  amplitude_unit: mV
dag:
  nodes:
    - id: 1
      stage: tbc_source
      node_type: SOURCE
      display_name: TBC Source
      user_label: TBC Source
      x: 50
      y: 50
      parameters:
        input_path:
          type: string
          value: /home/sdi/raid/decodes/bgbirds/set1_side1.tbc
        pcm_path:
          type: string
          value: /home/sdi/raid/decodes/bgbirds/set1_side1.pcm
    - id: 2
      stage: ffmpeg_video_sink
      node_type: SINK
      display_name: FFmpeg Video Sink
      user_label: FFmpeg Video Sink
      x: 725
      y: 50
    - id: 3
      stage: dropout_map
      node_type: TRANSFORM
      display_name: Dropout Map
      user_label: Dropout Map
      x: 275
      y: 50
      parameters:
        dropout_map:
          type: string
          value: "[{frame:0,remove:[{line:95,start:857,end:915}]},{frame:61,add:[{line:229,start:471,end:490}]}]"
    - id: 4
      stage: dropout_correct
      node_type: TRANSFORM
      display_name: Dropout Correction
      user_label: Dropout Correction
      x: 500
      y: 50
      parameters:
        highlight_corrections:
          type: bool
          value: false
        match_chroma_phase:
          type: bool
          value: true
        overcorrect_extension:
          type: uint32
          value: 0
    - id: 5
      stage: burst_level_analysis_sink
      node_type: ANALYSIS_SINK
      display_name: Burst Level Analysis Sink
      user_label: Burst Level Analysis Sink
      x: 275
      y: 175
    - id: 6
      stage: dropout_analysis_sink
      node_type: ANALYSIS_SINK
      display_name: Dropout Analysis Sink
      user_label: Dropout Analysis Sink
      x: 275
      y: 300
    - id: 7
      stage: snr_analysis_sink
      node_type: ANALYSIS_SINK
      display_name: SNR Analysis Sink
      user_label: SNR Analysis Sink
      x: 275
      y: 425
    - id: 8
      stage: dropout_analysis_sink
      node_type: ANALYSIS_SINK
      display_name: Dropout Analysis Sink
      user_label: Dropout Analysis Sink
      x: 725
      y: 175
  edges:
    - from: 1
      to: 3
    - from: 3
      to: 4
    - from: 4
      to: 2
    - from: 1
      to: 5
    - from: 1
      to: 6
    - from: 1
      to: 7
    - from: 4
      to: 8