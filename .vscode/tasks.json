{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Configure (cmake CLI)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-S",
				".",
				"-B",
				"build",
				"-DCMAKE_BUILD_TYPE=Debug",
				"-DBUILD_UNIT_TESTS=ON"
			],
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": false
			}
		},
		{
			"label": "Build (cmake CLI)",
			"type": "shell",
			"command": "cmake --build build --parallel",
			"args": [],
			"dependsOn": [
				"Configure (cmake CLI)"
			],
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Run Unit Tests",
			"type": "shell",
			"command": "ctest",
			"args": [
				"--test-dir",
				"build",
				"--output-on-failure"
			],
			"dependsOn": [
				"Build (cmake CLI)"
			],
			"problemMatcher": [],
			"group": {
				"kind": "test",
				"isDefault": true
			}
		},
		{
			"label": "Build efm sink plugin",
			"type": "shell",
			"command": "cmake --build build --parallel --target orc-stage-plugin-efm-sink",
			"isBackground": false,
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		}
	]
}